fic operation, please refer to\n    79→    /// [ClickHouse](https://clickhouse.com/docs/en/sql-reference/statements/alter/partition#drop-partitionpart)\n    80→    DropPartition { partition: Partition },\n    81→    /// `DROP PRIMARY KEY`\n    82→    ///\n    83→    /// Note: this is a MySQL-specific operation.\n    84→    DropPrimaryKey,\n    85→    /// `RENAME TO PARTITION (partition=val)`\n    86→    RenamePartitions {\n    87→        old_partitions: Vec<Expr>,\n    88→        new_partitions: Vec<Expr>,\n    89→    },\n    90→    /// Add Partitions\n    91→    AddPartitions {\n    92→        if_not_exists: bool,\n    93→        new_partitions: Vec<Expr>,\n    94→    },\n    95→    DropPartitions {\n    96→        partitions: Vec<Expr>,\n    97→        if_exists: bool,\n    98→    },\n    99→    /// `RENAME [ COLUMN ] <old_column_name> TO <new_column_name>`\n   100→    RenameColumn {\n   101→        old_column_name: Ident,\n   102→        new_column_name: Ident,\n   103→    },\n   104→    /// `RENAME TO <table_name>`\n   105→    RenameTable { table_name: ObjectName },\n   106→    // CHANGE [ COLUMN ] <old_name> <new_name> <data_type> [ <options> ]\n   107→    ChangeColumn {\n   108→        old_name: Ident,\n   109→        new_name: Ident,\n   110→        data_type: DataType,\n   111→        options: Vec<ColumnOption>,\n   112→    },\n   113→    /// `RENAME CONSTRAINT <old_constraint_name> TO <new_constraint_name>`\n   114→    ///\n   115→    /// Note: this is a PostgreSQL-specific operation.\n   116→    RenameConstraint { old_name: Ident, new_name: Ident },\n   117→    /// `ALTER [ COLUMN ]`\n   118→    AlterColumn {\n   119→        column_name: Ident,\n   120→        op: AlterColumnOperation,\n   121→    },\n   122→    /// `SWAP WITH <table_name>`\n   123→    ///\n   124→    /// Note: this is Snowflake specific <https://docs.snowflake.com/en/sql-reference/sql/alter-table>\n   125→    SwapWith { table_name: ObjectName },\n   126→\n   127→    /// `SET OPTIONS(table